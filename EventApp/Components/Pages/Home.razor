@page "/"
@attribute [Authorize]
@using EventApp.Models
@using EventApp.Services
@using EventApp.Components.Shared
@inject ItemService ItemService

<PageTitle>Home</PageTitle>

@* <main>
    <h1>Hello, world!</h1>

    Welcome to your new app.

    @foreach (var i in items)
    {
        <p>@i.Subject</p>
    }
</main> *@
<div class="calendar">
    <Calendar CurrentDate="CurrentDate"
              SelectedDate="SelectedDate"
              Items="Items"
              OnCurrentDateChanged="HandleMonthChange"
              OnDaySelected="SelectDay" />

    <ItemPanel SelectedDate="SelectedDate"
               Items="Items"
               OnItemSelected="FakeMethod" />
</div>

@code {
    // který den je zobrazen
    private DateTime CurrentDate = DateTime.Today;
    // na který den klikneme
    private DateTime? SelectedDate;
    private List<Item> Items = new();

    protected override void OnInitialized()
    {
        Items = ItemService.GetAll();
        //userId = httpContext.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    }

    private void HandleMonthChange(DateTime newDate)
    {
        CurrentDate = newDate;
    }

    private void SelectDay(DateTime date)
    {
        SelectedDate = date;
    }

    private void FakeMethod(Item item) {}
}
