@page "/"
@attribute [Authorize]
@using EventApp.Models
@using EventApp.Services
@using EventApp.Components.Shared
@inject ItemService ItemService

<PageTitle>Home</PageTitle>

@* <main>
    <h1>Hello, world!</h1>

    Welcome to your new app.

    @foreach (var i in items)
    {
        <p>@i.Subject</p>
    }
</main> *@
<div class="calendar">
    <Calendar CurrentDate="CurrentDate"
              SelectedDate="SelectedDate"
              Items="Items"
              OnCurrentDateChanged="HandleMonthChange"
              OnDaySelected="SelectDay" />

    <ItemPanel SelectedDate="SelectedDate"
               Items="Items"
               OnItemSelected="OpenDetail" />
</div>

<FabButton OnOpen="OpenModal" />

<ItemModal IsOpen="IsModalOpen"
           Item="SelectedItem"
           IsDetailMode="IsDetailMode"
           OnSave="HandleSave"
           OnDelete="HandleDelete"
           OnClose="CloseModal" />

@code {
    // který den je zobrazen
    private DateTime CurrentDate = DateTime.Today;
    // na který den klikneme
    private DateTime? SelectedDate;
    private List<Item> Items = new();

    protected override void OnInitialized()
    {
        Items = ItemService.GetAll();
        //userId = httpContext.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    }

    private void HandleMonthChange(DateTime newDate)
    {
        CurrentDate = newDate;
    }

    private void SelectDay(DateTime date)
    {
        SelectedDate = date;
    }

    /* modal */
    private bool IsModalOpen = false;

    private Item NewItem = new Item
    {
        Deadline = DateTime.Today
    };

    private Item? SelectedItem;

    private bool IsEditMode = false;
    private bool IsDetailMode = false;

    private void OpenModal()
    {
        SelectedItem = new Item
        {
            Deadline = SelectedDate ?? DateTime.Today
        };

        IsDetailMode = false;
        IsModalOpen = true;
    }

    private void OpenDetail(Item item)
    {
        SelectedItem = item;
        IsDetailMode = true;
        IsModalOpen = true;
    }

    private void HandleSave(Item item)
    {
        if (IsDetailMode)
            ItemService.Update(item);
        else
            ItemService.Add(item);

        ReloadItems();
    }

    private void HandleDelete(int id)
    {
        ItemService.Delete(id);
        ReloadItems();
    }

    private void ReloadItems()
    {
        Items = ItemService.GetAll();
        IsModalOpen = false;
        IsDetailMode = false;
    }

    private void CloseModal()
    {
        IsModalOpen = false;
    }

    private void EnableEdit()
    {
        IsEditMode = true;
    }

    private void SaveItem()
    {
        if (IsDetailMode)
        {
            ItemService.Update(NewItem);
        }
        else
        {
            ItemService.Add(NewItem);
        }

        Items = ItemService.GetAll();

        IsModalOpen = false;
        IsEditMode = false;
        IsDetailMode = false;
    }

    private void DeleteItem()
    {
        ItemService.Delete(NewItem.Id);

        Items = ItemService.GetAll();

        IsModalOpen = false;
        IsEditMode = false;
        IsDetailMode = false;

        // pokud smažu právě vybraný den, obnoví se panel
        if (SelectedDate != null &&
            !Items.Any(i => i.Deadline?.Date == SelectedDate.Value.Date))
        {
            StateHasChanged();
        }
    }
}
