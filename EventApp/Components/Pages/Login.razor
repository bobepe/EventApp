@page "/login"
@attribute [AllowAnonymous]
@inject NavigationManager Navigation

<main>
<h3>Přihlášení</h3>

<form method="post" action="/account/login" @formname="loginForm">
    <input type="hidden" name="ReturnUrl" value="@returnUrl" />

    <div class="mb-3">
            <label class="form-label" for="username" style="margin: 24px">Uživatelské jméno</label>
        <input id="username" name="Username" style="margin: 24px" />
    </div>

    <div class="mb-3">
            <label class="form-label" for="password" style="margin: 24px">Heslo</label>
        <input id="password" name="Password" type="password" style="margin: 24px" />
    </div>

    <button type="submit">Přihlásit</button>
</form>
</main>

@code {
    private string returnUrl = "/";

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        returnUrl = query["ReturnUrl"] ?? "/";
    }
}